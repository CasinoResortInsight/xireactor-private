# Copy to .env (gitignored) or export these before running the proxy.

# Default upstream Brilliant API the proxy forwards /api/* to when a request
# doesn't specify one.
BRILLIANT_API_BASE=http://localhost:8010

# Multi-KB: the SPA can target other Brilliant instances by sending an
# `X-KB-Base` header (managed in Settings → Knowledge bases). To restrict which
# upstreams the proxy will forward to, set a comma-separated allow-list here
# (exact base URLs). Leave unset on a trusted single-operator machine.
# BRILLIANT_ALLOWED_BASES=http://localhost:8010,https://kb.example.com

# --- Phase 6: Claude chat -----------------------------------------------------
# Required for the chat panel. Without it, the WebSocket returns a clear
# "chat unavailable" error and the rest of the console works normally.
ANTHROPIC_API_KEY=

# MCP transport for the agent's KB tools:
#   - Leave BRILLIANT_MCP_URL unset to launch the LOCAL stdio MCP server
#     (mcp/server.py). The agent acts as the chat user's API key.
#   - Set it to a remote HTTPS MCP endpoint to use streamable-http instead.
# BRILLIANT_MCP_URL=https://mcp.example.com/mcp

# Interpreter used to launch the local stdio MCP server (must have mcp/ deps).
# KB_CHAT_PYTHON=python

# Guardrails.
# KB_CHAT_MAX_TURNS=30
# KB_CHAT_DAILY_USD_BUDGET=5
